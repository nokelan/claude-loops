# claude-loops 환경 변수
# 복사 후 .env로 저장: cp .env.example .env

# Claude 홈 디렉토리 (기본값: ~/.claude)
CLAUDE_HOME=~/.claude

# 프로젝트 루트 (현재 작업 디렉토리로 대부분 자동 설정)
# PROJECT_ROOT=/path/to/your/project

# 텔레그램 설정 (m-search, dev 루프 알림용)
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 대화 아카이브 DB 경로 (m-search용)
RECORDINGS_DIR=~/Recordings

# Wiki 루트 (graphify용, 선택)
# WIKI_ROOT=~/wiki

# OpenAI API Key (dev-loopcode VERIFY-3 Codex 모드, 선택)
# OPENAI_API_KEY=sk-...
